---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <BaseHead title={`${SITE_TITLE} | 首頁`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="home-main">
      <!-- Hero Section -->
      <section class="hero-section">
        <div class="hero-content">
          <div class="badge">Consulting & Tech Blog</div>
          <h1 class="hero-title">
            探索軟體開發的精髓，<br />
            <span class="accent-text">加速您的職涯與技術成長</span>
          </h1>
          <p class="hero-subtitle">
            我是您的技術顧問。這裡分享關於系統架構、效能優化與雲端部署的實戰經驗，並提供一對一的專家線上諮詢服務。
          </p>
          <div class="hero-ctas">
            <a href="/blog" class="cta-button primary-cta">閱讀部落格文章</a>
            <a href="/booking" class="cta-button secondary-cta">預約一對一諮詢</a>
          </div>
        </div>
      </section>

      <!-- Services Grid -->
      <section class="services-section">
        <h2 class="section-title">我的服務與核心主題</h2>
        <div class="services-grid">
          <div class="glass-panel service-card">
            <div class="icon-wrapper">💻</div>
            <h3>技術架構設計</h3>
            <p>針對高併發、微服務與分散式系統，提供客製化的架構審查與設計建議，降低未來維護成本。</p>
          </div>
          <div class="glass-panel service-card">
            <div class="icon-wrapper">⚡</div>
            <h3>效能與 SEO 優化</h3>
            <p>深度的前端與後端效能分析，優化 Core Web Vitals，協助您的網站獲得搜尋引擎的最頂尖排名。</p>
          </div>
          <div class="glass-panel service-card">
            <div class="icon-wrapper">📅</div>
            <h3>線上諮詢預約</h3>
            <p>透過線上預約系統，讀者可以直接 booking 我的時間。針對職涯成長、技術瓶頸進行一對一解答。</p>
          </div>
        </div>
      </section>

      <!-- Latest Posts -->
      <section class="latest-posts-section">
        <div class="section-header">
          <h2 class="section-title">最新文章</h2>
          <a href="/blog" class="view-all-link">查看全部文章 &rarr;</a>
        </div>
        <div class="posts-grid">
          {posts.map((post) => (
            <article class="glass-panel post-card">
              <a href={`/blog/${post.id}/`} class="post-card-link">
                {post.data.heroImage && (
                  <div class="post-card-image-wrapper">
                    <img src={post.data.heroImage} alt={post.data.title} class="post-card-image" loading="lazy" />
                  </div>
                )}
                <div class="post-card-content">
                  <div class="post-date">
                    <FormattedDate date={post.data.pubDate} />
                  </div>
                  <h3 class="post-title">{post.data.title}</h3>
                  <p class="post-desc">{post.data.description}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .home-main {
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  /* Hero Section */
  .hero-section {
    padding: 3rem 0;
    text-align: center;
    position: relative;
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .badge {
    background: rgba(99, 102, 241, 0.1);
    color: var(--accent);
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    border: 1px solid rgba(99, 102, 241, 0.15);
  }

  .hero-title {
    font-size: 3.5rem;
    line-height: 1.15;
    margin: 0;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    max-width: 650px;
    line-height: 1.6;
    margin: 0;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .cta-button {
    padding: 0.8rem 1.8rem;
    border-radius: var(--border-radius-sm);
    font-weight: 600;
    font-size: 1rem;
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .primary-cta {
    background: var(--accent-gradient);
    color: #fff;
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
  }

  .primary-cta:hover {
    background: var(--accent-gradient-hover);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
  }

  .secondary-cta {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }

  .secondary-cta:hover {
    background: var(--bg-primary);
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  /* Services Section */
  .services-section {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .section-title {
    font-size: 2.25rem;
    text-align: center;
    margin: 0;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .service-card {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .icon-wrapper {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .service-card h3 {
    font-size: 1.35rem;
    margin: 0;
  }

  .service-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.6;
  }

  /* Latest Posts Section */
  .latest-posts-section {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .section-header .section-title {
    text-align: left;
  }

  .view-all-link {
    font-weight: 600;
    font-size: 1rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .post-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .post-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .post-card-image-wrapper {
    aspect-ratio: 16/9;
    overflow: hidden;
    border-bottom: 1px solid var(--border-color);
  }

  .post-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    box-shadow: none;
    transition: transform var(--transition-slow);
  }

  .post-card:hover .post-card-image {
    transform: scale(1.05);
  }

  .post-card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-grow: 1;
  }

  .post-date {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .post-title {
    font-size: 1.25rem;
    line-height: 1.4;
    margin: 0;
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }

  .post-card:hover .post-title {
    color: var(--accent);
  }

  .post-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .services-grid, .posts-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .hero-title {
      font-size: 2.5rem;
    }
  }
</style>
